{
  "author": "",
  "description": "WOPR TTS plugin for Chatterbox (OpenAI-compatible)",
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/node": "^25.2.3",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "wopr",
    "plugin",
    "tts",
    "chatterbox",
    "voice",
    "speech"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "name": "@wopr-network/wopr-plugin-voice-chatterbox",
  "scripts": {
    "build": "tsc",
    "check": "biome check index.ts __tests__/ && tsc --noEmit",
    "clean": "rm -rf dist",
    "format": "biome format --write index.ts __tests__/",
    "lint": "biome check index.ts __tests__/",
    "lint:fix": "biome check --fix index.ts __tests__/",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "version": "1.0.0",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "release": {
    "extends": "@wopr-network/semantic-release-config"
  },
  "wopr": {
    "plugin": {
      "category": "voice",
      "description": "Chatterbox TTS with voice cloning",
      "install": [
        {
          "image": "devnen/chatterbox-tts-server",
          "kind": "docker",
          "label": "Pull Chatterbox TTS server",
          "tag": "latest"
        }
      ],
      "name": "voice-chatterbox",
      "requires": {
        "docker": [
          "devnen/chatterbox-tts-server:latest"
        ]
      },
      "type": "tts"
    }
  }
}
